@host = http://localhost:5041
@contentType = application/json

# ==============================================================
# HEALTH CHECK
# ==============================================================

### Health check (no auth required)
GET {{host}}/api/tasks/IAM/Health
Accept: {{contentType}}

###

# ==============================================================
# IAM — REGISTER
# ==============================================================

### Register a new member account
POST {{host}}/api/tasks/IAM/Register
Content-Type: {{contentType}}

{
  "email": "nicole@prodash.dev",
  "password": "Secret123!",
  "userRole": 1
}

###

### Register an admin account
POST {{host}}/api/tasks/IAM/Register
Content-Type: {{contentType}}

{
  "email": "admin@prodash.dev",
  "password": "Admin123!",
  "userRole": 0
}

###

### Register duplicate — should fail with 400
POST {{host}}/api/tasks/IAM/Register
Content-Type: {{contentType}}

{
  "email": "nicole@prodash.dev",
  "password": "Secret123!",
  "userRole": 1
}

###

# ==============================================================
# IAM — LOGIN
# Copy the accessToken from the response and set @token below
# ==============================================================

### Login as member
POST {{host}}/api/tasks/IAM/Login
Content-Type: {{contentType}}

{
  "email": "nicole@prodash.dev",
  "password": "Secret123!"
}

###

### Login as admin
POST {{host}}/api/tasks/IAM/Login
Content-Type: {{contentType}}

{
  "email": "admin@prodash.dev",
  "password": "Admin123!"
}

###

### Login with wrong password — should fail with 400
POST {{host}}/api/tasks/IAM/Login
Content-Type: {{contentType}}

{
  "email": "nicole@prodash.dev",
  "password": "WrongPassword"
}

###

### Login with unknown email — should fail with 400
POST {{host}}/api/tasks/IAM/Login
Content-Type: {{contentType}}

{
  "email": "ghost@prodash.dev",
  "password": "Secret123!"
}

###

# ==============================================================
# Set your token here after logging in above
# ==============================================================
@token = PASTE_ACCESS_TOKEN_HERE

# ==============================================================
# IAM — FORGOT / RESET PASSWORD
# ==============================================================

### Forgot password (generates reset token, logs it server-side)
POST {{host}}/api/tasks/IAM/ForgotPassword
Content-Type: {{contentType}}

{
  "email": "nicole@prodash.dev"
}

###

### Reset password (use token from server logs)
POST {{host}}/api/tasks/IAM/ResetPassword
Content-Type: {{contentType}}

{
  "email": "nicole@prodash.dev",
  "token": "PASTE_RESET_TOKEN_HERE",
  "newPassword": "NewSecret123!"
}

###

### Reset password with expired/invalid token — should fail
POST {{host}}/api/tasks/IAM/ResetPassword
Content-Type: {{contentType}}

{
  "email": "nicole@prodash.dev",
  "token": "invalid-token",
  "newPassword": "NewSecret123!"
}

###

# ==============================================================
# TASKS — CRUD (requires auth)
# ==============================================================

### Get all tasks
GET {{host}}/api/tasks/Task
Authorization: Bearer {{token}}
Accept: {{contentType}}

###

### Get task by ID
GET {{host}}/api/tasks/Task/1
Authorization: Bearer {{token}}
Accept: {{contentType}}

###

### Get non-existent task — should return 404
GET {{host}}/api/tasks/Task/99999
Authorization: Bearer {{token}}
Accept: {{contentType}}

###

### Create a new task (ToDo)
POST {{host}}/api/tasks/Task
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "title": "Build dashboard component",
  "description": "Create the main productivity dashboard with charts",
  "dueDate": "2026-05-15T00:00:00Z",
  "status": 1,
  "hoursWorked": 0
}

###

### Create another task (InProgress)
POST {{host}}/api/tasks/Task
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "title": "Write unit tests",
  "description": "Cover all service layer methods",
  "dueDate": "2026-05-20T00:00:00Z",
  "status": 2,
  "hoursWorked": 3
}

###

### Create task without auth — should fail with 401
POST {{host}}/api/tasks/Task
Content-Type: {{contentType}}

{
  "title": "Unauthorized task",
  "status": 1
}

###

### Update task — change status to Done
PUT {{host}}/api/tasks/Task/1
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "title": "Build dashboard component",
  "description": "Done — shipped to staging",
  "status": 3
}

###

### Update task — partial update (just status)
PUT {{host}}/api/tasks/Task/2
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "status": 3
}

###

### Delete task (Admin only) — use admin token
DELETE {{host}}/api/tasks/Task/1
Authorization: Bearer {{token}}

###

### Delete task as non-admin — should fail with 403
DELETE {{host}}/api/tasks/Task/2
Authorization: Bearer {{token}}

###

# ==============================================================
# USERS — USER MANAGEMENT (requires auth)
# ==============================================================

### Get user profile
POST {{host}}/api/tasks/User/GetUserProfile
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "email": "nicole@prodash.dev"
}

###

### Update user
POST {{host}}/api/tasks/User/UpdateUser
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "email": "nicole@prodash.dev",
  "password": "NewSecret123!",
  "userRole": 1
}

###

### Get all users (Admin only)
POST {{host}}/api/tasks/User/GetAllUsers
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

###

### Get all users without auth — should fail with 401
POST {{host}}/api/tasks/User/GetAllUsers
Content-Type: {{contentType}}

###
